{
  "name": "@blitzpress/core-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build": "bun run build:app && bun run build:modules",
    "build:app": "bunx vite build --mode app",
    "build:modules": "bunx vite build --mode modules",
    "test": "bun test --preload ./src/test/setup.ts",
    "typecheck": "bunx tsc --noEmit"
  },
  "dependencies": {
    "solid-js": "^1.9.5"
  },
  "devDependencies": {
    "bun-types": "^1.3.9",
    "typescript": "^5.8.3",
    "vite": "^5.4.18",
    "vite-plugin-solid": "^2.11.6"
  }
}
