        {
          "type": "frame",
          "id": "9lWnZ",
          "name": "annotSec",
          "width": "fill_container",
          "layout": "vertical",
          "gap": 12,
          "padding": [
            24,
            0,
            0,
            0
          ],
          "children": [
            {
              "type": "text",
              "id": "xfIhi",
              "name": "annotTitle",
              "fill": "$fg-primary",
              "content": "Design Rationale",
              "fontFamily": "Inter",
              "fontSize": 20,
              "fontWeight": "700"
            },
            {
              "type": "text",
              "id": "V4ZFl",
              "name": "ann1",
              "fill": "$fg-secondary",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "This system is structurally familiar to WordPress admin users but visually more modern, spacious, and polished. The dark sidebar with light content area creates a clear hierarchy between navigation and workspace. Neutral gray foundations with a single blue accent keep the interface trustworthy without being clinical.",
              "fontFamily": "Inter",
              "fontSize": 14,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "L5Rl9",
              "name": "ann2",
              "fill": "$fg-secondary",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "All components use design token variables for colors, spacing, and radii, ensuring consistent theming and future dark mode support. Plugin-contributed pages inherit the same card, table, and form patterns, making third-party extensions feel native. The semantic color system ensures status is communicated through both color and text, meeting AA accessibility requirements.",
              "fontFamily": "Inter",
              "fontSize": 14,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "Pz71E",
              "name": "ann3",
              "fill": "$fg-secondary",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "Font: Inter (UI) + Geist Mono (data). Spacing: 4px base unit. Elevation: minimal, only cards and modals. Interaction: visible focus rings using accent-primary, minimum 44px touch targets on mobile.",
              "fontFamily": "Inter",
              "fontSize": 14,
              "fontWeight": "normal"
            }
          ]
        }
      ]
    },
