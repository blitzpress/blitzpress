    {
      "type": "frame",
      "id": "pY2XM",
      "x": -101,
      "y": 584,
      "name": "Shell Annotations",
      "width": 400,
      "fill": "$bg-primary",
      "cornerRadius": "$radius-xl",
      "stroke": {
        "align": "inside",
        "thickness": 1,
        "fill": "$border-default"
      },
      "layout": "vertical",
      "gap": 16,
      "padding": 24,
      "children": [
        {
          "type": "text",
          "id": "G72MJ",
          "name": "annTitle",
          "fill": "$fg-primary",
          "content": "Shell Design Annotations",
          "fontFamily": "Inter",
          "fontSize": 18,
          "fontWeight": "700"
        },
        {
          "type": "text",
          "id": "kIOCN",
          "name": "ann1",
          "fill": "$fg-secondary",
          "textGrowth": "fixed-width",
          "width": "fill_container",
          "content": "SIDEBAR (260px expanded, 64px collapsed)\nDark bg-sidebar (#1B1E2B) for clear separation from content. Plugin-injected nav items appear under a PLUGINS section label. Items support icon + label + optional badge. Nested items indent to 42px left padding.",
          "lineHeight": 1.6,
          "fontFamily": "Inter",
          "fontSize": 13,
          "fontWeight": "normal"
        },
        {
          "type": "text",
          "id": "TItB7",
          "name": "ann2",
          "fill": "$fg-secondary",
          "textGrowth": "fixed-width",
          "width": "fill_container",
          "content": "TOP BAR (56px fixed height)\nSticky, white background with bottom border. Left: breadcrumbs. Right: search, notifications, avatar. Remains stable regardless of page content weight.",
          "lineHeight": 1.6,
          "fontFamily": "Inter",
          "fontSize": 13,
          "fontWeight": "normal"
        },
        {
          "type": "text",
          "id": "gZo6S",
          "name": "ann3",
          "fill": "$fg-secondary",
          "textGrowth": "fixed-width",
          "width": "fill_container",
          "content": "PAGE CONTAINER\n32px padding with 24px gap between sections. bg-secondary (#F7F8FA) background separates content from chrome. Page header with title + description + action buttons is the standard pattern.",
          "lineHeight": 1.6,
          "fontFamily": "Inter",
          "fontSize": 13,
          "fontWeight": "normal"
        },
        {
          "type": "text",
          "id": "FVXOI",
          "name": "ann4",
          "fill": "$fg-secondary",
          "textGrowth": "fixed-width",
          "width": "fill_container",
          "content": "RESPONSIVE BEHAVIOR\nDesktop: full sidebar + topbar + content.\nCollapsed: 64px icon sidebar, expand via panel-left icon.\nMobile: no sidebar, hamburger triggers off-canvas drawer overlay with scrim. Content stacks vertically, stat cards go full-width.",
          "lineHeight": 1.6,
          "fontFamily": "Inter",
          "fontSize": 13,
          "fontWeight": "normal"
        },
        {
          "type": "text",
          "id": "Qmlit",
          "name": "ann5",
          "fill": "$fg-secondary",
          "textGrowth": "fixed-width",
          "width": "fill_container",
          "content": "PLUGIN EXTENSION\nPlugins register menu items via manifest. Items appear under a dedicated section label in the sidebar. Plugin-contributed pages use the same page header + card/table patterns from the design system to feel native.",
          "lineHeight": 1.6,
          "fontFamily": "Inter",
          "fontSize": 13,
          "fontWeight": "normal"
        }
      ]
    },
